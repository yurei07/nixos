input {
    focus-follows-mouse
    disable-power-key-handling
    workspace-auto-back-and-forth

    touchpad {
        tap
        natural-scroll
        drag false
        click-method "button-areas"
        scroll-method "two-finger"
        accel-speed 0.20
        accel-profile "adaptive"
        tap-button-map "left-right-middle"
        scroll-factor 1.0
    }

    mouse {
        accel-speed 0.20
        accel-profile "adaptive"
        scroll-factor 1.0
    }

    keyboard {
        track-layout "window"
        xkb {
            layout "us,ru,de"
            options "grp:alt_shift_toggle"
        }
        repeat-delay 600
        repeat-rate 25
    }
}

// --- MONITORS ---
// Primary Monitor
output "DP-1" {
    mode "2560x1440@164.999"
    scale 1.0
    position x=0 y=0
}

// Secondary Monitor (Vertical)
output "DP-2" {
    mode "2560x1080@199.997"
    scale 1.0
    transform "270"
    position x=-1080 y=0
}

// --- VISUALS ---
overview {
    zoom 0.4
}

// ANIMATIONS: Using "Spring" curves for a smooth, high-end feel
animations {
    // Uncomment to turn off all animations.
    // You can also put "off" into each individual animation to disable it.
    // off

    // Slow down all animations by this factor. Values below 1 speed them up instead.
    // slowdown 3.0

    // Individual animations.

    workspace-switch {
        spring damping-ratio=1.0 stiffness=1000 epsilon=0.0001
    }

    window-open {
        duration-ms 150
        curve "ease-out-expo"
    }

    window-close {
        duration-ms 150
        curve "ease-out-quad"
    }

    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    window-movement {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    window-resize {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    config-notification-open-close {
        spring damping-ratio=0.6 stiffness=1000 epsilon=0.001
    }

    exit-confirmation-open-close {
        spring damping-ratio=0.6 stiffness=500 epsilon=0.01
    }

    screenshot-ui-open {
        duration-ms 200
        curve "ease-out-quad"
    }

    overview-open-close {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    recent-windows-close {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.001
    }
}

layout {
    shadow {
        on
    }

    gaps 24
    default-column-display "normal"
    center-focused-column "on-overflow"

    struts {
        left 0
        right 0
        top 0
        bottom 0
    }

    focus-ring {
        on
        width 2
        active-color "#8771DA"
    }

    border {
        off
        width 4
        active-color "#8771DA"
    }

    insert-hint {
        color "#ffc87f70"
    }

    tab-indicator {
        hide-when-single-tab
        place-within-column
        corner-radius 4
        width 4
        length total-proportion=1.0
        gap 4
        gaps-between-tabs 2
    }
}

// --- WINDOW RULES ---
prefer-no-csd

window-rule {
    match is-active=false
}

window-rule {
    geometry-corner-radius 20
    clip-to-geometry true
}

// --- STARTUP ---
spawn-at-startup "noctalia-shell"
spawn-at-startup "swaybg" "-i" "/path/to/your/wallpaper" 

// --- BINDINGS ---
binds {
    // System
    Mod+Shift+Slash { show-hotkey-overlay; }
    Mod+Shift+E { quit; }
    Mod+Q { close-window; }

    // Apps
    Mod+Return { spawn "kitty"; }
    Mod+Y { spawn "sh" "-c" "/etc/nixos/scripts/nvim.sh"; }
    Mod+E { spawn "nautilus"; }
    Mod+B { spawn "zen"; }
    Mod+D { spawn "vesktop"; }
    // Overview 
    Mod+O { toggle-overview; }
    
    // Launcher
    Mod+Space { spawn "noctalia-shell" "ipc" "call" "launcher" "toggle"; }

    // Screenshots
    Print { screenshot; }
    Shift+Print { screenshot-screen; }
    
    // Instant Replay (GPU Screen Recorder)
    Mod+Ctrl+R { spawn "sh" "-c" "killall -SIGUSR1 gpu-screen-recorder && notify-send 'GPU-Screen-Recorder' 'Replay saved successfully'"; }

    // Multimedia
    XF86AudioRaiseVolume allow-when-locked=true { spawn "noctalia-shell" "ipc" "call" "volume" "increase"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "noctalia-shell" "ipc" "call" "volume" "decrease"; }
    XF86AudioMute        allow-when-locked=true { spawn "noctalia-shell" "ipc" "call" "volume" "muteOutpute"; }
    
    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "set" "5%+"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "set" "5%-"; }

    // Navigation
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+H     { focus-column-left; }
    Mod+L     { focus-column-right; }
    Mod+J     { focus-window-down; }
    Mod+K     { focus-window-up; }

    // Moving Windows
    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+Right { move-column-right; }
    Mod+Shift+H     { move-column-left; }
    Mod+Shift+L     { move-column-right; }

    // Workspaces
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }

    // Layout Management
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }
    Mod+V { toggle-window-floating; }
    Mod+R { switch-preset-column-width; }
    Mod+C { center-column; }
    
    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }

    // --- MOUSE WHEEL NAVIGATION ---

    // Super + Wheel: Switch between windows (columns)
    Mod+WheelScrollDown      { focus-column-right; }
    Mod+WheelScrollUp        { focus-column-left; }

    // Alt + Wheel: Switch between workspaces
    // Using Alt (A) as requested
    Alt+WheelScrollDown      { focus-workspace-down; }
    Alt+WheelScrollUp        { focus-workspace-up; }

    // --- QUICK NAVIGATION (First / Last Window) ---

    // Switch to the first window on the workspace
    Mod+Home { focus-column-first; }

    // Switch to the last window on the workspace
    Mod+End  { focus-column-last; }

    // Alternative: if you want to use keys like 1 and 9 for first/last
    // Mod+Shift+1 { focus-column-first; }
    // Mod+Shift+9 { focus-column-last; }
}

// LAYER RULES
layer-rule {
    match namespace="launcher"
}
